# Stingray — environment configuration
# Copy this file to `.env` and adjust values for your environment.
# Compose automatically loads `.env` from the project root.

# -- LLM (Ollama) --
# URL of the Ollama server reachable from inside the containers.
# On macOS/Windows Docker Desktop, host.docker.internal points at the host.
# On Linux, replace with the host's LAN IP or run Ollama in another container.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# -- PostgreSQL --
POSTGRES_USER=stingray
POSTGRES_PASSWORD=stingray
POSTGRES_DB=stingray

# Connection string used by web/fetcher containers. The hostname `postgres`
# resolves to the postgres service on the compose network — leave it as-is
# unless you are pointing at an external database.
DATABASE_URL=postgresql://stingray:stingray@postgres:5432/stingray

# -- Web server --
# Host port mapped to the web container's 20080.
WEB_PORT=20080

# -- Frontend dev server --
# Vite dev server proxies /api to this URL. Override if the backend is not
# on localhost (e.g. running in docker on a different host).
VITE_API_PROXY=http://localhost:20080
