<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>News Report - {{ date.strftime('%Y-%m-%d') }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Noto Sans JP", sans-serif;
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
      background: #1a1a1a;
      color: #d4d4d4;
      line-height: 1.6;
    }
    h1 {
      font-size: 1.6rem;
      border-bottom: 2px solid #888;
      padding-bottom: 8px;
      margin-bottom: 24px;
      color: #e0e0e0;
    }
    h1 span { font-weight: normal; color: #777; font-size: 1.0rem; }
    h2 {
      font-size: 1.3rem;
      margin: 24px 0 12px;
      padding: 4px 8px;
      background: #2a2a2a;
      color: #ccc;
      border-left: 3px solid #5a9cf5;
    }
    .article {
      padding: 10px 0;
      border-bottom: 1px solid #333;
    }
    .article:last-child { border-bottom: none; }
    .article-title {
      color: #e0e0e0;
      font-weight: 500;
      font-size: 1.15rem;
    }
    .article-title a {
      color: #e0e0e0;
      text-decoration: none;
    }
    .article-title a:hover {
      text-decoration: underline;
    }
    .article-title-original a {
      font-size: 0.9rem;
      color: #8899aa;
      text-decoration: none;
      margin-top: 1px;
    }
    .article-title-original a:hover {
      text-decoration: underline;
      color: #aabbcc;
    }
    .article-domain {
      font-size: 0.8rem;
      color: #555;
      font-weight: normal;
    }
    .article-meta {
      font-size: 0.9rem;
      color: #666;
      margin-top: 2px;
    }
    .article-snippet {
      margin-top: 4px;
      font-size: 0.95rem;
      color: #888;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .article-summary {
      margin-top: 4px;
      font-size: 1.0rem;
      color: #aaa;
    }
    footer {
      margin-top: 32px;
      padding-top: 12px;
      border-top: 1px solid #333;
      font-size: 0.9rem;
      color: #555;
    }
  </style>
</head>
<body>
  <h1>
    News Report
    <span>{{ date.strftime('%Y-%m-%d') }} / {{ total }} articles</span>
  </h1>

  {% for source, articles in grouped.items() %}
  <h2>{{ source }} ({{ articles|length }})</h2>
  {% for article in articles %}
  <div class="article">
    {% if article.title_ja and article.title_ja != article.title %}
    <div class="article-title">{{ article.title_ja }}</div>
    <div class="article-title-original"><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a> <span class="article-domain">({{ article.url|domain }})</span></div>
    {% else %}
    <div class="article-title"><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a> <span class="article-domain">({{ article.url|domain }})</span></div>
    {% endif %}
    {% if article.published %}
    <div class="article-meta">{{ article.published|jst }}</div>
    {% endif %}
    {% if article.content_snippet %}
    <div class="article-snippet">{{ article.content_snippet }}</div>
    {% endif %}
    {% if article.summary %}
    <div class="article-summary">{{ article.summary }}</div>
    {% endif %}
  </div>
  {% endfor %}
  {% endfor %}

  <footer>Generated by news-aggregator</footer>
</body>
</html>
