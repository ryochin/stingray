<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>News Report - {{ date.strftime('%Y-%m-%d') }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Noto Sans JP", sans-serif;
      background: #1a1a1a;
      color: #d4d4d4;
      line-height: 1.6;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }
    header {
      padding: 16px 24px;
      border-bottom: 1px solid #333;
      background: #1e1e1e;
      flex-shrink: 0;
    }
    header h1 {
      font-size: 1.4rem;
      color: #e0e0e0;
    }
    header h1 span { font-weight: normal; color: #777; font-size: 0.95rem; margin-left: 8px; }
    .layout {
      display: flex;
      flex: 1;
      min-height: 0;
    }
    .sidebar {
      width: 220px;
      flex-shrink: 0;
      background: #1e1e1e;
      border-right: 1px solid #333;
      overflow-y: auto;
      padding: 8px 0;
    }
    .sidebar-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 16px;
      cursor: pointer;
      color: #999;
      font-size: 0.9rem;
      border-left: 3px solid transparent;
      transition: background 0.15s, color 0.15s;
      user-select: none;
    }
    .sidebar-item:hover {
      background: #252525;
      color: #ccc;
    }
    .sidebar-item.active {
      background: #252525;
      color: #e0e0e0;
      border-left-color: #5a9cf5;
    }
    .sidebar-item .count {
      font-size: 0.75rem;
      background: #333;
      color: #888;
      padding: 1px 7px;
      border-radius: 10px;
    }
    .sidebar-item.active .count {
      background: #3a5a8a;
      color: #9cc0f0;
    }
    .content {
      flex: 1;
      overflow-y: auto;
      padding: 20px 28px;
      min-width: 0;
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .tab-panel h2 {
      font-size: 1.2rem;
      margin-bottom: 16px;
      padding: 4px 8px;
      background: #2a2a2a;
      color: #ccc;
      border-left: 3px solid #5a9cf5;
    }
    .article {
      padding: 12px 0;
      border-bottom: 1px solid #2a2a2a;
    }
    .article:last-child { border-bottom: none; }
    .article-title {
      color: #e0e0e0;
      font-weight: 500;
      font-size: 1.15rem;
    }
    .article-title a {
      color: #e0e0e0;
      text-decoration: none;
    }
    .article-title a:hover { text-decoration: underline; }
    .article-title-original a {
      font-size: 0.9rem;
      color: #8899aa;
      text-decoration: none;
      margin-top: 1px;
    }
    .article-title-original a:hover {
      text-decoration: underline;
      color: #aabbcc;
    }
    .article-domain {
      font-size: 0.8rem;
      color: #555;
      font-weight: normal;
    }
    .article-meta {
      font-size: 0.9rem;
      color: #666;
      margin-top: 2px;
    }
    .article-snippet {
      margin-top: 4px;
      font-size: 0.95rem;
      color: #888;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .article-summary {
      margin-top: 4px;
      font-size: 1.0rem;
      color: #aaa;
    }
    footer {
      padding: 12px 24px;
      border-top: 1px solid #333;
      font-size: 0.85rem;
      color: #555;
      background: #1e1e1e;
      flex-shrink: 0;
    }

    @media (max-width: 700px) {
      .sidebar { width: 180px; }
      .content { padding: 16px; }
    }
    @media (max-width: 500px) {
      .layout { flex-direction: column; }
      .sidebar {
        width: 100%;
        border-right: none;
        border-bottom: 1px solid #333;
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        padding: 0;
        flex-shrink: 0;
      }
      .sidebar-item {
        white-space: nowrap;
        border-left: none;
        border-bottom: 3px solid transparent;
        padding: 10px 14px;
      }
      .sidebar-item.active {
        border-bottom-color: #5a9cf5;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>
      News Report
      <span>{{ date.strftime('%Y-%m-%d') }} / {{ total }} articles</span>
    </h1>
  </header>

  <div class="layout">
    <nav class="sidebar">
      {% for source, articles in grouped.items() %}
      <div class="sidebar-item{% if loop.first %} active{% endif %}" data-tab="tab-{{ loop.index }}">
        <span>{{ source }}</span>
        <span class="count">{{ articles|length }}</span>
      </div>
      {% endfor %}
    </nav>

    <main class="content">
      {% for source, articles in grouped.items() %}
      <div class="tab-panel{% if loop.first %} active{% endif %}" id="tab-{{ loop.index }}">
        <h2>{{ source }} ({{ articles|length }})</h2>
        {% for article in articles %}
        <div class="article">
          {% if article.title_ja and article.title_ja != article.title %}
          <div class="article-title">{{ article.title_ja }}</div>
          <div class="article-title-original"><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a> <span class="article-domain">({{ article.url|domain }})</span></div>
          {% else %}
          <div class="article-title"><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a> <span class="article-domain">({{ article.url|domain }})</span></div>
          {% endif %}
          {% if article.published %}
          <div class="article-meta">{{ article.published|jst }}</div>
          {% endif %}
          {% if article.content_snippet %}
          <div class="article-snippet">{{ article.content_snippet }}</div>
          {% endif %}
          {% if article.summary %}
          <div class="article-summary">{{ article.summary }}</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </main>
  </div>

  <footer>Generated by news-aggregator</footer>

  <script>
    document.querySelectorAll(".sidebar-item").forEach((item) => {
      item.addEventListener("click", () => {
        document.querySelectorAll(".sidebar-item").forEach((el) => el.classList.remove("active"))
        document.querySelectorAll(".tab-panel").forEach((el) => el.classList.remove("active"))
        item.classList.add("active")
        document.getElementById(item.dataset.tab).classList.add("active")
        document.querySelector(".content").scrollTop = 0
      })
    })
  </script>
</body>
</html>
